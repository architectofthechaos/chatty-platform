# Database connection string
# For local dev with SQLite: sqlite:///./chatty.db
# For Docker/Postgres: postgresql://chatty:chatty@db:5432/chatty
DATABASE_URL=sqlite:///./chatty.db

# Comma-separated list of allowed CORS origins
# Use * for development, explicit origins for production
CORS_ALLOWED_ORIGINS=*

# Port the application listens on
APP_PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Postgres settings (used by docker-compose for the db service)
POSTGRES_USER=chatty
POSTGRES_PASSWORD=chatty
POSTGRES_DB=chatty
